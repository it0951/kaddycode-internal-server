# =============================================
# KaddyCode Internal Server - 환경변수 템플릿
# =============================================
# 이 파일을 복사하여 .env 파일로 만들고 실제 값을 채워주세요.
# cp .env.example .env

# ----- Database -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kaddycode
DB_USER=kaddycode
DB_PASSWORD=

# ----- Qdrant -----
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_HTTP_PORT=6333
QDRANT_REST_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=kaddycode-vectors
QDRANT_VECTOR_SIZE=3584

# ----- Ollama -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_PORT=11434

# ----- AI API Keys -----
#OPENAI_API_KEY=
#CLAUDE_API_KEY=
#GEMINI_API_KEY=

# ----- Backoffice -----
BACKOFFICE_URL=http://localhost:8080
BACKOFFICE_ADMIN_EMAIL=admin@kaddycode.com
BACKOFFICE_ADMIN_PASSWORD=

# ----- Tenant -----
TENANT_AUTH_ENABLED=true

# ----- App -----
APP_PORT=8081
